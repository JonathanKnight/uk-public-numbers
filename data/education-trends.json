  "_tuition_fees": {
    "label": "Annual tuition fee cap for home undergraduates, England",
    "source_url": "https://www.gov.uk/government/publications/higher-education-and-research-act-2017-tuition-fee-limits",
    "note": "Maximum annual fee chargeable to home (UK-domicile) undergraduate students at English higher education providers. Fees were introduced in 1998 (means-tested, upfront). Variable fees up to £3,000 were introduced from 2006-07 following the 2004 Higher Education Act. The 2012 tripling to £9,000 followed the Browne Review. The cap was frozen at £9,250 from 2017 to 2024, representing a significant real-terms cut in universities' income per student.",
    "series": [
      { "year": "1997-98", "fee": 0,    "note": "Free tuition" },
      { "year": "1998-99", "fee": 1000, "note": "Means-tested upfront fee introduced" },
      { "year": "2006-07", "fee": 3070, "note": "Variable fees up to £3,000 + RPI" },
      { "year": "2012-13", "fee": 9000, "note": "Fee tripling following Browne Review" },
      { "year": "2017-18", "fee": 9250, "note": "Cap raised; frozen until 2024" },
      { "year": "2025-26", "fee": 9535, "note": "First real-terms rise since 2017" }
    ]
  },

